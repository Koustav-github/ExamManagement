# Copy to .env and fill in real values. NEVER commit the real .env.

# --- Database ---
DATABASE_URL='postgresql+psycopg2://user:password@host/dbname?sslmode=require'

# --- JWT ---
JWT_SECRET_KEY='change-me-to-a-long-random-string'
ALGORITHM='HS256'
ACCESS_TOKEN_EXPIRE_MINUTES='15'
REFRESH_TOKEN_EXPIRE_DAYS='7'

# --- Cookies / CORS ---
# false for local HTTP dev; true in prod (HTTPS only)
SECURE_COOKIES=false
# Origin used once CORS is tightened from "*". See README § Design decisions.
FRONTEND_ORIGIN='http://localhost:5173'

# --- SMTP (optional; /admin/students/email returns 503 if unset) ---
# Gmail: use an App Password, not your real password.
SMTP_HOST='smtp.gmail.com'
SMTP_PORT='587'
SMTP_USER='you@gmail.com'
SMTP_PASSWORD='your-app-password'
SMTP_FROM='you@gmail.com'

# --- Tests ---
# DEDICATED test DB. The suite DROPs public schema at session start.
TEST_DATABASE_URL='postgresql+psycopg2://user:password@localhost/academic_test'
